// 003 Database (DBML)
// Purpose: define relational schema when a database is part of the system.
// This sample repo is documentation-only, so the model below is illustrative.

Table guidance_documents {
  id int [pk, increment]
  path varchar [not null, unique]
  kind varchar [not null, note: 'agents|instruction|spec|wal']
  updated_at timestamp [not null]
}

Table guidance_references {
  id int [pk, increment]
  from_document_id int [not null, ref: > guidance_documents.id]
  to_document_id int [not null, ref: > guidance_documents.id]
  relation varchar [not null, note: 'requires|extends|related']
}
